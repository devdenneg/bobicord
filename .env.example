# Неизменяемый SHA-тег образов из успешного deploy workflow (40 hex-символов), не latest.
IMAGE_TAG=replace_with_deployed_git_sha

# LiveKit API-ключ и секрет.
# ДОЛЖНЫ совпадать с блоком keys: в livekit.yaml
LK_KEY=APIxxxxxxxxxxxx
LK_SECRET=your_livekit_secret_here

# Секрет для подписи JWT сессий пользователей.
# Сгенерируй: openssl rand -hex 32
SESSION_SECRET=change_me_to_random_hex

# Отдельный секрет для короткоживущих service-JWT виртуального медиарелея.
# Сгенерируй НОВОЕ значение той же командой; оно не должно совпадать с SESSION_SECRET.
# Это же значение вручную устанавливается как VRELAY_AUTH_SECRET на media VPS.
VRELAY_AUTH_SECRET=change_me_to_a_different_random_hex
# Аварийный мост только на время первого rollout: 1 временно разрешает старому vrelay
# legacy-токены на SESSION_SECRET. После обновления удалённого compose/образа немедленно вернуть 0.
VRELAY_ACCEPT_LEGACY_SESSION_TOKEN=0

# Авторизация по email и восстановление пароля. Начни с disabled для теста доставки, затем optional
# покажет миграцию новым клиентам без серверной блокировки старых, и только после привязки адресов
# required включит обязательную проверку на API.
APP_PUBLIC_URL=https://reelay.online
AUTH_EMAIL_ENFORCEMENT=disabled
# Дополнительные доверенные origin через запятую. Основной веб-домен и Tauri уже разрешены кодом.
CORS_ALLOWED_ORIGINS=

# Публичные данные отправителя и SMTP-подключения. Для порта 587: SECURE=0 + обязательный STARTTLS.
# Для провайдера с implicit TLS на 465 используй SECURE=1; не отключай проверку сертификата.
MAIL_FROM_NAME=RelayApp
MAIL_FROM_ADDRESS=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_REQUIRE_TLS=1
SMTP_USER=

# Это ПУТИ, не сами секреты. /dev/null безопасно сохраняет старый optional-rollout запускаемым.
# Перед required создай файлы на основном API VPS и укажи канонические пути ниже:
# SMTP_PASSWORD_SECRET_FILE=/opt/voice/secrets/smtp_password
# AUTH_CODE_PEPPER_SECRET_FILE=/opt/voice/secrets/auth_code_pepper
SMTP_PASSWORD_SECRET_FILE=/dev/null
AUTH_CODE_PEPPER_SECRET_FILE=/dev/null

# Короткие коды одноразовые; повторная отправка не должна сбрасывать счётчик неудачных попыток.
EMAIL_CODE_TTL_SEC=600
EMAIL_CODE_MAX_ATTEMPTS=5
EMAIL_SEND_COOLDOWN_SEC=60
EMAIL_SEND_MAX_PER_HOUR=5
PASSWORD_RESET_TTL_SEC=900
PASSWORD_RESET_SEND_COOLDOWN_SEC=60
REGISTRATION_INVITE_TIMEZONE=Europe/Moscow
REGISTRATION_INVITE_MAX_USES=25
REGISTRATION_INVITE_MAX_EMAILS=50

# LiveKit WS-URL, отдаётся клиенту в токене (тот же, что node_ip/домен LiveKit).
LK_WS_URL=wss://138-16-170-21.sslip.io

# Медиа-стек (vrelay + coturn) вынесен на отдельный VPS: deploy/vrelay-remote/. Здесь оба
# сервиса лежат под профилем local-media и по умолчанию НЕ поднимаются.
#   пусто        — штатно: медиаузел и TURN удалённые
#   local-media  — откат: поднять vrelay+coturn рядом с token (сначала погасить удалённые,
#                  иначе два агента и findVrelayAgent() возьмёт того, кто подключился раньше)
COMPOSE_PROFILES=

# coturn (Evolution-TZ Э3): STUN/TURN для relay-дерева.
# TURN_SECRET должен совпадать с --static-auth-secret coturn (docker-compose.yml) — в том
# числе с coturn на удалённом VPS, он валидирует те же временные креды (turnCreds.js).
# Пусто = TURN отключён, дереву достаётся только STUN (как раньше).
# Сгенерируй: openssl rand -hex 32
TURN_SECRET=change_me_to_random_hex
TURN_REALM=relayapp.local
# Список TURN-URI через запятую, домен/IP — публичный адрес VPS с coturn. Медиа-стек вынесен
# на отдельный VPS (см. COMPOSE_PROFILES ниже), поэтому здесь адрес ТОГО хоста, не этого.
TURN_URLS=turn:77.110.113.200:3478,turn:77.110.113.200:3478?transport=tcp
# TTL временных TURN-креды, секунды.
TURN_TTL_SEC=600
# Список STUN-URI через запятую. Свой STUN — тот же coturn (Binding-запросы авторизации не
# требуют). Google оставлен последним страховкой: coturn лёг, а vrelay жив — srflx-кандидат
# всё равно добывается. Пусто = дефолт tree.js (только Google).
STUN_URLS=stun:77.110.113.200:3478,stun:stun.l.google.com:19302
# Д8: coturn --external-ip. НУЖЕН ТОЛЬКО ЕСЛИ coturn ЗА NAT — т.е. на интерфейсе висит
# приватный адрес, а публичный отображается снаружи (AWS/GCP и подобные).
# Проверить на VPS:   ip -4 addr show scope global | grep inet    vs    curl -4 ifconfig.me
#   совпали  -> публичный IP прямо на интерфейсе (Hetzner/DO/Vultr) -> ОСТАВЬ ПУСТЫМ
#   не совпали -> впиши публичный IPv4 (пример: TURN_EXTERNAL_IP=203.0.113.10)
# Пусто = флаг не добавляется (coturn падает на пустом значении, потому и ${VAR:+...}).
TURN_EXTERNAL_IP=
# Привязать coturn к публичному интерфейсу (--listening-ip + --relay-ip). Без этого он
# слушает ВСЕ интерфейсы, включая docker-мосты 172.17/18/19.x, и предлагает на них
# relay-кандидаты — зритель зря жжёт ICE-таймауты. Впиши публичный IPv4 VPS.
# Пусто = слушать всё (прежнее поведение). Пример: TURN_LISTEN_IP=203.0.113.10
TURN_LISTEN_IP=

# Э9/Д1: виртуальный relay (сервис vrelay). Сколько прямых детей держит виртуальный узел
# в одном дереве. Это ГЛАВНЫЙ рычаг исходящей полосы VPS:
#     egress ≈ битрейт_стрима × VRELAY_MAX_CHILDREN
# При server-first (Д8, дефолт-on) через виртуала идёт ВЕСЬ видеотрафик, поэтому
# переоценка = потери пакетов у всех зрителей сразу. Недооценка безопасна: когда слоты
# виртуала кончились, зрители ретранслируют друг другу (Д6 супер-сидеры) — дерево ветвится.
#
# ЗАМЕР ПОЛОСЫ. speedtest-cli на проде не работает (API speedtest.net). Одиночный TCP-поток
# ЗАНИЖАЕТ на длинном RTT (упирается в окно, а не в канал) — мерить ТОЛЬКО параллельно:
#   TMP=$(mktemp); dd if=/dev/zero of=$TMP bs=1M count=25
#   IF=$(ip route get 1.1.1.1 | awk '{print $5; exit}')
#   t1=$(cat /sys/class/net/$IF/statistics/tx_bytes); s1=$(date +%s%N)
#   seq 6 | xargs -P6 -I{} curl -4 -s -o /dev/null -X POST --data-binary @$TMP \
#       https://speed.cloudflare.com/__up
#   t2=$(cat /sys/class/net/$IF/statistics/tx_bytes); s2=$(date +%s%N)
#   awk -v b=$((t2-t1)) -v ns=$((s2-s1)) 'BEGIN{printf "%.1f Мбит/с\n", b*8/(ns/1e9)/1e6}'
# Мерить на ПРОСТАИВАЮЩЕМ хосте (иначе получишь остаток, а не ёмкость).
#
# Формула: VRELAY_MAX_CHILDREN = (замеренная_Мбит × 0.7) / битрейт_Мбит
# Прод 138.16.170.21 (замер 2026-07-09): upload ~37 Мбит/с -> (37×0.7)/6 ≈ 4.
# Серверный потолок — VRELAY_CHILDREN_CAP (tree.js VIRTUAL_CHILDREN_CAP, дефолт 32).
VRELAY_MAX_CHILDREN=4
# Исходящая полоса виртуального узла (Мбит/с). НИЧЕГО не ограничивает — уходит в
# available_outgoing -> stats -> outBonus серверного скоринга best-peer (кого выбрать
# родителем). Завышение = сервер считает себя бесконечно жирным и перетягивает зрителей.
# Ставь ЗАМЕРЕННУЮ полосу, не пиковую по тарифу.
VRELAY_OUT_MBPS=37
# Д1 server-first: серверный кап прямых детей виртуала (tree.js VIRTUAL_CHILDREN_CAP).
#VRELAY_CHILDREN_CAP=32

# Д2/Д4: сколько ffmpeg-транскодов (рендишнов) vrelay держит одновременно.
# 0 = рендишны ОТКЛЮЧЕНЫ: остаётся source-only passthrough, зритель получает
# 'rendition-unavailable', меню качества пусто. Дерево и server-first работают как обычно.
#
# ТРАНСКОД CPU-ДОРОГ: это декод входного H.264 (1080p60) + масштабирование + x264-энкод.
# Ориентир ~1 ядро на один 720p30-рендишн (superfast/zerolatency), ~0.6 на 480p30.
# Прод 138.16.170.21 — ОДНО vCPU @2.25GHz (KVM), делит ядро с livekit(голос!)/coturn/
# token/caddy/teamspeak. Один ffmpeg выест ядро и задушит голосовой канал -> дефолт 0.
# Поднимать только на VPS с выделенными ядрами (>= 2 свободных на рендишн с запасом).
VRELAY_MAX_TRANSCODES=0

# Roadmap-flow-стриминга Д8: инверсия топологии «стример → сервер → зрители» (vrelay —
# постоянный медиаузел) — ДЕФОЛТ on (дефолт в коде tree.js: != '0'). Откат на legacy = 0.
# Действует только для стримов, где натив-вещатель прислал serverIngest:true; старые бандлы
# (без поля) идут по legacy-fallback даже при server-first дефолт-on.
TREE_SERVER_FIRST=1

# Web Push (VAPID) — фоновые уведомления PWA/браузера (упоминания, трансляции).
# Можно НЕ задавать: сервер сам сгенерирует пару и стабильно сохранит в data/vapid.json
# (том persist). Если задаёшь вручную — сгенерируй: npx web-push generate-vapid-keys
# ВАЖНО: смена ключей инвалидирует все существующие подписки (юзерам надо переподписаться).
VAPID_PUBLIC=
VAPID_PRIVATE=
# Контакт для APNs/FCM (по стандарту Web Push). mailto: или https://.
VAPID_SUBJECT=mailto:admin@relay.app

# Медиа-релей YouTube (совместное прослушивание) — обход блокировки: официальный IFrame-плеер
# тянет аудио с googlevideo.com напрямую в браузер, у заблокированных провайдером не играет.
# Отдельный бокс (deploy/media-relay/) извлекает аудио через yt-dlp и проксирует браузеру; этот
# сервер лишь подписывает HMAC-токен (аудио идёт браузер↔релей, мимо ЭТОГО VPS — egress-инвариант).
# Пусто = фича выключена: /api/music/resolve отдаёт 503, плеер показывает «релей недоступен».
# MEDIA_RELAY_SECRET печатает deploy/media-relay/setup.sh; ДОЛЖЕН совпадать с секретом на боксе.
MEDIA_RELAY_URL=https://media.reelay.online
MEDIA_RELAY_SECRET=change_me_same_as_relay_box
