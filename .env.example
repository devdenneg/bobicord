# LiveKit API-ключ и секрет.
# ДОЛЖНЫ совпадать с блоком keys: в livekit.yaml
LK_KEY=APIxxxxxxxxxxxx
LK_SECRET=your_livekit_secret_here

# Секрет для подписи JWT сессий пользователей.
# Сгенерируй: openssl rand -hex 32
SESSION_SECRET=change_me_to_random_hex

# LiveKit WS-URL, отдаётся клиенту в токене (тот же, что node_ip/домен LiveKit).
LK_WS_URL=wss://138-16-170-21.sslip.io

# coturn (Evolution-TZ Э3): STUN/TURN для relay-дерева.
# TURN_SECRET должен совпадать с --static-auth-secret coturn (docker-compose.yml).
# Пусто = TURN отключён, дереву достаётся только STUN (как раньше).
# Сгенерируй: openssl rand -hex 32
TURN_SECRET=change_me_to_random_hex
TURN_REALM=relayapp.local
# Список TURN-URI через запятую, домен/IP — публичный адрес VPS с coturn.
TURN_URLS=turn:138-16-170-21.sslip.io:3478,turn:138-16-170-21.sslip.io:3478?transport=tcp
# TTL временных TURN-креды, секунды.
TURN_TTL_SEC=600
# Д8: coturn --external-ip. НУЖЕН ТОЛЬКО ЕСЛИ coturn ЗА NAT — т.е. на интерфейсе висит
# приватный адрес, а публичный отображается снаружи (AWS/GCP и подобные).
# Проверить на VPS:   ip -4 addr show scope global | grep inet    vs    curl -4 ifconfig.me
#   совпали  -> публичный IP прямо на интерфейсе (Hetzner/DO/Vultr) -> ОСТАВЬ ПУСТЫМ
#   не совпали -> впиши публичный IPv4 (пример: TURN_EXTERNAL_IP=203.0.113.10)
# Пусто = флаг не добавляется (coturn падает на пустом значении, потому и ${VAR:+...}).
TURN_EXTERNAL_IP=
# Привязать coturn к публичному интерфейсу (--listening-ip + --relay-ip). Без этого он
# слушает ВСЕ интерфейсы, включая docker-мосты 172.17/18/19.x, и предлагает на них
# relay-кандидаты — зритель зря жжёт ICE-таймауты. Впиши публичный IPv4 VPS.
# Пусто = слушать всё (прежнее поведение). Пример: TURN_LISTEN_IP=203.0.113.10
TURN_LISTEN_IP=

# Э9/Д1: виртуальный relay (сервис vrelay). Сколько прямых детей держит виртуальный узел
# в одном дереве. Это ГЛАВНЫЙ рычаг исходящей полосы VPS:
#     egress ≈ битрейт_стрима × VRELAY_MAX_CHILDREN
# При server-first (Д8, дефолт-on) через виртуала идёт ВЕСЬ видеотрафик, поэтому
# переоценка = потери пакетов у всех зрителей сразу. Недооценка безопасна: когда слоты
# виртуала кончились, зрители ретранслируют друг другу (Д6 супер-сидеры) — дерево ветвится.
# Поэтому дефолт консервативный. Подъём — ТОЛЬКО после замера полосы на VPS:
#     speedtest-cli --simple      (или iperf3 до внешнего хоста)
# Формула: VRELAY_MAX_CHILDREN = (замеренная_Мбит × 0.7) / битрейт_Мбит
#   пример: порт 100 Мбит, стрим 6 Мбит -> (100×0.7)/6 ≈ 11
#   пример: порт 1 Гбит,  стрим 6 Мбит -> (1000×0.7)/6 ≈ 116 -> упрётся в VRELAY_CHILDREN_CAP
# Серверный потолок — VRELAY_CHILDREN_CAP (tree.js VIRTUAL_CHILDREN_CAP, дефолт 32).
VRELAY_MAX_CHILDREN=12
# Исходящая полоса виртуального узла (Мбит/с). НИЧЕГО не ограничивает — уходит в
# available_outgoing -> stats -> outBonus серверного скоринга best-peer (кого выбрать
# родителем). Завышение = сервер считает себя бесконечно жирным и перетягивает зрителей.
# Ставь ЗАМЕРЕННУЮ полосу, не пиковую по тарифу.
VRELAY_OUT_MBPS=50
# Д1 server-first: серверный кап прямых детей виртуала (tree.js VIRTUAL_CHILDREN_CAP).
#VRELAY_CHILDREN_CAP=32

# Roadmap-flow-стриминга Д8: инверсия топологии «стример → сервер → зрители» (vrelay —
# постоянный медиаузел) — ДЕФОЛТ on (дефолт в коде tree.js: != '0'). Откат на legacy = 0.
# Действует только для стримов, где натив-вещатель прислал serverIngest:true; старые бандлы
# (без поля) идут по legacy-fallback даже при server-first дефолт-on.
TREE_SERVER_FIRST=1

# Web Push (VAPID) — фоновые уведомления PWA/браузера (упоминания, трансляции).
# Можно НЕ задавать: сервер сам сгенерирует пару и стабильно сохранит в data/vapid.json
# (том persist). Если задаёшь вручную — сгенерируй: npx web-push generate-vapid-keys
# ВАЖНО: смена ключей инвалидирует все существующие подписки (юзерам надо переподписаться).
VAPID_PUBLIC=
VAPID_PRIVATE=
# Контакт для APNs/FCM (по стандарту Web Push). mailto: или https://.
VAPID_SUBJECT=mailto:admin@relay.app
