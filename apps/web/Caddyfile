# reelay.online (+ www) — основной домен: полный апп. Легаси 138-16-170-21.sslip.io оставлен рабочим
# для старых нативных клиентов, LiveKit (LK_WS_URL) и updater — но визит в БРАУЗЕРЕ на sslip.io редиректит
# на reelay.online (только корень/SPA; backend-пути /api,/tree,/ws,/rtc НЕ редиректим — WS/API их не переживут).
# Caddy сам берёт Let's Encrypt на каждый хост. Запечён в web-образ.

# Общие backend-прокси (одинаковы для обоих доменов)
(backend) {
	handle /rtc* {
		reverse_proxy 127.0.0.1:7880
	}
	handle /twirp* {
		reverse_proxy 127.0.0.1:7880
	}
	handle /api* {
		reverse_proxy 127.0.0.1:3000
	}
	handle /tree* {
		reverse_proxy 127.0.0.1:3000
	}
	# Глобальный notify-WS (уведомления по любому серверу, вкл. не подключённый). Без этого
	# правила /ws уходил в fallback-статику (index.html), upgrade падал → notify-WS не коннектился.
	handle /ws* {
		reverse_proxy 127.0.0.1:3000
	}
}

reelay.online, www.reelay.online {
	import backend
	handle {
		root * /srv
		header Cache-Control "no-store, no-cache, must-revalidate"
		header Pragma "no-cache"
		try_files {path} /index.html
		file_server
	}
}

138-16-170-21.sslip.io {
	import backend
	# всё, что не backend (корень + SPA-маршруты), — на нормальный домен
	handle {
		redir https://reelay.online{uri} permanent
	}
}
