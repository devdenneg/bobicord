# reelay.online (+ www) — основной домен: полный апп. Легаси 138-16-170-21.sslip.io оставлен рабочим
# для старых нативных клиентов, LiveKit (LK_WS_URL) и updater — но визит в БРАУЗЕРЕ на sslip.io редиректит
# на reelay.online (только корень/SPA; backend-пути /api,/tree,/ws,/rtc НЕ редиректим — WS/API их не переживут).
# Caddy сам берёт Let's Encrypt на каждый хост. Запечён в web-образ.

# Общие backend-прокси (одинаковы для обоих доменов)
(backend) {
	handle /rtc* {
		reverse_proxy 127.0.0.1:7880
	}
	handle /twirp* {
		reverse_proxy 127.0.0.1:7880
	}
	handle /api* {
		reverse_proxy 127.0.0.1:3000
	}
	handle /tree* {
		reverse_proxy 127.0.0.1:3000
	}
	# Глобальный notify-WS (уведомления по любому серверу, вкл. не подключённый). Без этого
	# правила /ws уходил в fallback-статику (index.html), upgrade падал → notify-WS не коннектился.
	handle /ws* {
		reverse_proxy 127.0.0.1:3000
	}
}

reelay.online, www.reelay.online {
	header {
		Referrer-Policy "no-referrer"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		Content-Security-Policy "default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'wasm-unsafe-eval' https://www.youtube.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://cdn.7tv.app https://i.ytimg.com https://yt3.ggpht.com; font-src 'self' data:; connect-src 'self' https://7tv.io https://cdn.7tv.app https://www.youtube.com https://media.reelay.online wss://reelay.online wss://www.reelay.online wss://138-16-170-21.sslip.io wss://media.reelay.online; media-src 'self' blob: https://media.reelay.online; worker-src 'self' blob:; frame-src https://www.youtube.com https://www.youtube-nocookie.com; manifest-src 'self'"
	}
	import backend
	handle {
		root * /srv
		header Cache-Control "no-store, no-cache, must-revalidate"
		header Pragma "no-cache"
		try_files {path} /index.html
		file_server
	}
}

138-16-170-21.sslip.io {
	header {
		Referrer-Policy "no-referrer"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Strict-Transport-Security "max-age=31536000"
		Content-Security-Policy "default-src 'none'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'"
	}
	import backend
	# всё, что не backend (корень + SPA-маршруты), — на нормальный домен
	handle {
		redir https://reelay.online{uri} permanent
	}
}
