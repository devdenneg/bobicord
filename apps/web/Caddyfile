# Основной домен reelay.online (+ www) и легаси 138-16-170-21.sslip.io (нативные клиенты со старым
# запечённым URL продолжают работать); все три → один backend, Caddy берёт Let's Encrypt на каждый.
# Запечён в web-образ.
reelay.online, www.reelay.online, 138-16-170-21.sslip.io {
	handle /rtc* {
		reverse_proxy 127.0.0.1:7880
	}
	handle /twirp* {
		reverse_proxy 127.0.0.1:7880
	}
	handle /api* {
		reverse_proxy 127.0.0.1:3000
	}
	handle /tree* {
		reverse_proxy 127.0.0.1:3000
	}
	# Глобальный notify-WS (уведомления по любому серверу, вкл. не подключённый). Без этого
	# правила /ws уходил в fallback-статику (index.html), upgrade падал → notify-WS не коннектился.
	handle /ws* {
		reverse_proxy 127.0.0.1:3000
	}
	handle {
		root * /srv
		header Cache-Control "no-store, no-cache, must-revalidate"
		header Pragma "no-cache"
		try_files {path} /index.html
		file_server
	}
}
