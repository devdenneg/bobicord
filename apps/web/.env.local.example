# Скопируй в .env.local (npm run dev читает автоматически).
#
# true  → dev-фронт ходит на ПРОД-бэкенд, локальный бэк поднимать НЕ нужно.
#         Внимание: работаешь с реальной прод-БД и живыми юзерами.
# false → фронт ждёт бэк на http://localhost:3000 (подними бэк локально).
USE_PROD_BACKEND=true

# (опц.) переопределить адрес прод-бэка:
# PROD_API_URL=https://138-16-170-21.sslip.io
