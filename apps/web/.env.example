# Видео-транспорт: livekit (SFU, default) | tree (P2P relay-дерево, Evolution-TZ Э2+).
# tree — браузер только смотрит (лист), вещание из веба недоступно (native-only).
VITE_VIDEO_TRANSPORT=livekit

# Опционально — переопределить ws-адрес дерева (по умолчанию строится из текущего
# origin: wss://<host>/tree, что и проксирует Caddy в проде).
# VITE_TREE_WS_URL=ws://localhost:3000/tree
