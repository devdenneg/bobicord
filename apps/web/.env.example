# Опционально — переопределить ws-адрес дерева (по умолчанию строится из текущего
# origin: wss://<host>/tree, что и проксирует Caddy в проде).
# VITE_TREE_WS_URL=ws://localhost:3000/tree

# Опционально — базовый URL REST API. По умолчанию пусто: запросы идут на
# текущий origin (/api/...), это и проксирует Caddy в проде для веба.
# Нужен для нативного (Tauri) клиента (Э4+): вебвью грузит локальный bundle,
# у него нет reverse-proxy на бэкенд, поэтому указываем адрес явно.
# VITE_API_BASE_URL=https://138-16-170-21.sslip.io

# GIPHY picker для фона профиля. Создай отдельный key для этой платформы
# (web и desktop builds используют разные ключи):
# https://developers.giphy.com/dashboard/
# VITE_GIPHY_API_KEY=your_web_key
