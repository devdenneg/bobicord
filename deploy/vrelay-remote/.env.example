# .env для медиа-стека на отдельном VPS. Копируется в /opt/vrelay/.env.
#
# БЕЗОПАСНОСТЬ: media VPS получает только узкий VRELAY_AUTH_SECRET для service-JWT дерева.
# Пользовательский SESSION_SECRET сюда никогда не копируется. Держи файл chmod 600; при утечке
# ротируй VRELAY_AUTH_SECRET согласованно на основном API и здесь.
#   chmod 600 /opt/vrelay/.env

# Неизменяемый SHA-тег образа из успешного workflow deploy (40 hex-символов), не latest.
VRELAY_IMAGE_TAG=replace_with_deployed_git_sha

# Отдельный случайный секрет минимум 32 байта. Должен совпадать с VRELAY_AUTH_SECRET основного
# API, но НЕ с SESSION_SECRET. Генерация: openssl rand -hex 32. Без него vrelay падает на старте.
VRELAY_AUTH_SECRET=change_me_same_as_main_api_vrelay_secret

# Публичный /tree прод-Caddy (control-WS сигналинга дерева). Агент — WS-клиент, коннектится
# сюда исходящим. Дефолт в compose: wss://reelay.online/tree
TREE_WS_URL=wss://reelay.online/tree

# Тот же, что в .env прод-сервера: token выдаёт временные TURN-креды, coturn их валидирует.
TURN_SECRET=change_me_same_as_prod
TURN_REALM=relayapp.local

# Публичный IPv4 ЭТОГО хоста. Обязателен: без него coturn слушает и приватные адреса
# (10.x на eth0/eth1, docker0 172.17.x) и раздаёт на них недостижимые relay-кандидаты.
TURN_LISTEN_IP=77.110.113.200
# Пусто, если публичный IPv4 висит прямо на интерфейсе (DO/Hetzner/Vultr). Заполнять только
# когда coturn реально за NAT. Проверка:
#   ip -4 addr show scope global | grep inet   vs   curl -4 ifconfig.me
TURN_EXTERNAL_IP=

# Прямых детей у медиаузла: (замеренная_отдача_Мбит × 0.7) / битрейт_стрима_Мбит.
VRELAY_MAX_CHILDREN=8
# ЗАМЕРЕННАЯ устойчивая отдача, не тарифная. Мерить 6 параллельными потоками — одиночный
# врёт (окно × RTT):  iperf3 -c <host> -P 6 -R
# Завышение = ядро дропает исходящие UDP (SndbufErrors), фризы у ВСЕХ зрителей разом.
# 77.110.113.200 (Москва, замер 2026-07-10, curl 20МБ speed.cloudflare.com ×2): 195-207 Мбит/с → 80.
VRELAY_OUT_MBPS=80
# Одновременных ffmpeg-транскодов. Один 720p30-рендишн ≈ одно ядро.
VRELAY_MAX_TRANSCODES=1
VRELAY_IDLE_SEC=60
VRELAY_MAX_STREAMS=8
# webrtc_srtp=warn обязателен: шторм «srtp ... duplicated» на INFO при ретрансмитах вещателя
# (~1200 строк/с) топит лог и хоронит реальный сигнал IngestMonitor.
RUST_LOG=info,interceptor::nack=error,webrtc_ice=error,dtls=error,webrtc_srtp=warn
